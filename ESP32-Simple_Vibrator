#simple code but you need to break the sensor circuit for the sensor to detect
from machine import Pin
from time import sleep_ms

sensor = Pin(26, Pin.IN)
red = Pin(4, Pin.OUT)
green = Pin(27, Pin.OUT)

while True:
    if sensor.value() == 0:
        print("SHAKE DETECTED")
        red.on()
        green.off()
        sleep_ms(300)
    else:
        red.off()
        green.on()

    sleep_ms(50)
